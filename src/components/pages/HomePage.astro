---
import type { CollectionEntry } from "astro:content";
import { type SupportedLocale } from "@i18n/locales";
import type { Page } from "astro";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import Pagination from "../control/Pagination.astro";
import PostPage from "../PostPage.astro";

const { page, locale } = Astro.props as {
	page: Page<CollectionEntry<"posts">>;
	locale: SupportedLocale;
};

const len = page.data.length;
---

<MainGridLayout locale={locale}>
	<PostPage page={page} locale={locale}></PostPage>
	<Pagination
		class="mx-auto onload-animation"
		page={page}
		locale={locale}
		style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
	></Pagination>
</MainGridLayout>
