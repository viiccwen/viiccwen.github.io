---
import { DEFAULT_LOCALE, type SupportedLocale } from "@i18n/locales";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getTagList } from "../../utils/content-utils";
import { getTagUrl } from "../../utils/url-utils";
import ButtonTag from "../control/ButtonTag.astro";
import WidgetLayout from "./WidgetLayout.astro";

const COLLAPSED_HEIGHT = "7.5rem";

interface Props {
	class?: string;
	style?: string;
	locale?: SupportedLocale;
}
const className = Astro.props.class;
const style = Astro.props.style;
const { locale = DEFAULT_LOCALE } = Astro.props as {
	locale?: SupportedLocale;
};
const tags = await getTagList(locale);
const isCollapsed = tags.length >= 20;
---
<WidgetLayout name={i18n(I18nKey.tags, locale)} id="tags" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT} class={className} style={style} locale={locale}>
    <div class="flex gap-2 flex-wrap">
        {tags.map(t => (
            <ButtonTag href={getTagUrl(t.name, locale)} label={`View all posts with the ${t.name.trim()} tag`}>
                {t.name.trim()}
            </ButtonTag>
        ))}
    </div>
</WidgetLayout>
